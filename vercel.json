{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "installCommand": "composer install --no-dev --optimize-autoloader --no-interaction && npm install",
  "buildCommand": "npm run build",

  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },

  "outputDirectory": "public",

  "crons": [
    {
      "path": "/api/internal/sync-traffic",
      "schedule": "0 0 * * *"
    }
  ],

  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}
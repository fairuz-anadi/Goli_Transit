{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },

  "outputDirectory": "public/build",

  "rewrites": [
    {
      "source": "/build/(.*)",
      "destination": "/build/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}